<% const currentListUrl = returnTo || (buildQuery() ? `/admin/announcements?${buildQuery()}` : '/admin/announcements'); %>
<section class="page-grid">
  <div class="panel workspace-panel">
    <div class="section-head">
      <div>
        <h3 class="section-title">公告发布</h3>
      </div>
      <div class="section-actions">
        <a
          href="/admin/announcements/new?return_to=<%= encodeURIComponent(returnTo) %>"
          class="primary-button"
          data-admin-modal
        >
          新增公告
        </a>
      </div>
    </div>

    <form class="filter-shell mb-4" method="get">
      <input class="form-control" name="keyword" placeholder="搜索标题或正文" value="<%= filters.keyword %>" />
      <select class="form-select" name="target_role">
        <option value="">全部角色</option>
        <% ['all', 'student', 'teacher', 'admin'].forEach(function(target) { %>
          <option value="<%= target %>" <%= filters.target_role === target ? 'selected' : '' %>><%= targetRoleLabel(target) %></option>
        <% }) %>
      </select>
      <select class="form-select" name="category">
        <option value="">全部分类</option>
        <% ['系统公告', '教学通知', '学业预警'].forEach(function(category) { %>
          <option value="<%= category %>" <%= filters.category === category ? 'selected' : '' %>><%= category %></option>
        <% }) %>
      </select>
      <button class="primary-button" type="submit">筛选公告</button>
    </form>

    <% if (announcements.length) { %>
      <div class="table-scroll table-scroll-module">
        <table class="data-table">
        <thead>
          <tr>
            <th>标题</th>
            <th>面向角色</th>
            <th>分类</th>
            <th>优先级</th>
            <th>发布时间</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% announcements.forEach(function(item) { %>
            <tr>
              <td><strong><%= item.title %></strong></td>
              <td><%= targetRoleLabel(item.target_role) %></td>
              <td><span class="status-pill <%= badgeClass(item.category) %>"><%= item.category %></span></td>
              <td><span class="status-pill <%= badgeClass(item.priority) %>"><%= item.priority %></span></td>
              <td><%= item.published_at ? dayjs(item.published_at).format('YYYY-MM-DD HH:mm') : '--' %></td>
              <td class="table-actions">
                <a href="/announcements/<%= item.id %>?back=<%= encodeURIComponent(currentListUrl) %>" class="ghost-button">详情</a>
                <a
                  href="/admin/announcements/<%= item.id %>/edit?return_to=<%= encodeURIComponent(returnTo) %>"
                  class="ghost-button"
                  data-admin-modal
                >
                  编辑
                </a>
                <form action="/admin/announcements/<%= item.id %>" method="post" data-confirm="确认删除这条公告？">
                  <input type="hidden" name="_method" value="DELETE" />
                  <input type="hidden" name="return_to" value="<%= returnTo %>" />
                  <button type="submit" class="ghost-button">删除</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
        </table>
      </div>
      <div class="mt-4">
        <%- include('../../partials/pagination', { pagination: pagination }) %>
      </div>
    <% } else { %>
      <%- include('../../partials/empty-state', {
        title: '没有找到符合条件的公告',
        icon: 'solar:chat-round-call-linear'
      }) %>
      <div class="mt-3">
        <a
          href="/admin/announcements/new?return_to=<%= encodeURIComponent(returnTo) %>"
          class="primary-button"
          data-admin-modal
        >
          新增公告
        </a>
      </div>
    <% } %>
  </div>
</section>
