<% const item = moduleItem || {}; %>
<div class="row g-3 w-100">
  <div class="col-md-4">
    <label class="field-label">所属学期</label>
    <input class="form-control" type="number" min="1" max="8" name="semester_no" value="<%= item.semester_no || 1 %>" required />
  </div>
  <div class="col-md-4">
    <label class="field-label">模块名称</label>
    <input class="form-control" name="module_name" value="<%= item.module_name || '' %>" required />
  </div>
  <div class="col-md-4">
    <label class="field-label">模块类型</label>
    <input class="form-control" name="module_type" value="<%= item.module_type || '专业核心' %>" required />
  </div>
  <div class="col-md-4">
    <label class="field-label">要求学分</label>
    <input class="form-control" type="text" value="<%= `${formatScore(item.required_credits || 0)} 学分（由模块课程自动汇总）` %>" readonly />
  </div>
</div>
