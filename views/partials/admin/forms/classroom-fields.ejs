<% const item = classroom || {}; %>
<div class="row g-3 w-100">
  <div class="col-md-6">
    <label class="field-label">教学楼</label>
    <input class="form-control" name="building_name" value="<%= item.building_name || '' %>" required />
  </div>
  <div class="col-md-6">
    <label class="field-label">教室号</label>
    <input class="form-control" name="room_number" value="<%= item.room_number || '' %>" required />
  </div>
  <div class="col-md-6">
    <label class="field-label">容量</label>
    <input class="form-control" type="number" name="capacity" value="<%= item.capacity || 40 %>" required />
  </div>
  <div class="col-md-6">
    <label class="field-label">教室类型</label>
    <input class="form-control" name="room_type" value="<%= item.room_type || '标准教室' %>" />
  </div>
</div>
