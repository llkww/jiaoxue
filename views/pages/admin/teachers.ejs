<section class="page-grid">
  <div class="panel workspace-panel">
    <div class="section-head">
      <div>
        <h3 class="section-title">教师档案</h3>
      </div>
      <div class="section-actions">
        <a
          href="/admin/teachers/new?return_to=<%= encodeURIComponent(returnTo) %>"
          class="primary-button"
          data-admin-modal
        >
          新增教师
        </a>
      </div>
    </div>

    <form class="filter-shell mb-4" method="get">
      <input class="form-control" name="keyword" placeholder="搜索工号、姓名或账号" value="<%= filters.keyword %>" />
      <select class="form-select" name="department_id">
        <option value="">全部院系</option>
        <% departments.forEach(function(item) { %>
          <option value="<%= item.id %>" <%= String(filters.department_id) === String(item.id) ? 'selected' : '' %>><%= item.name %></option>
        <% }) %>
      </select>
      <button class="primary-button" type="submit">筛选教师</button>
    </form>

    <% if (teachers.length) { %>
      <div class="table-scroll table-scroll-module">
        <table class="data-table">
          <thead>
            <tr>
              <th>教师</th>
              <th>院系</th>
              <th>职称</th>
              <th>联系方式</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% teachers.forEach(function(item) { %>
              <tr>
                <td>
                  <strong><%= item.full_name %></strong>
                  <div class="muted-copy"><%= item.teacher_no %> · <%= item.username %></div>
                </td>
                <td><%= item.department_name %></td>
                <td><%= item.title || '--' %></td>
                <td>
                  <div><%= item.phone || '--' %></div>
                  <div class="muted-copy"><%= item.email || '--' %></div>
                </td>
                <td class="table-actions">
                  <a
                    href="/admin/teachers/<%= item.id %>/edit?return_to=<%= encodeURIComponent(returnTo) %>"
                    class="ghost-button"
                    data-admin-modal
                  >
                    编辑
                  </a>
                  <form action="/admin/teachers/<%= item.id %>" method="post" data-confirm="确认删除该教师账号和档案？">
                    <input type="hidden" name="_method" value="DELETE" />
                    <input type="hidden" name="return_to" value="<%= returnTo %>" />
                    <button type="submit" class="ghost-button">删除</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <div class="mt-4">
        <%- include('../../partials/pagination', { pagination: pagination }) %>
      </div>
    <% } else { %>
      <%- include('../../partials/empty-state', {
        title: '没有找到符合条件的教师',
        icon: 'solar:user-id-linear'
      }) %>
      <div class="mt-3">
        <a
          href="/admin/teachers/new?return_to=<%= encodeURIComponent(returnTo) %>"
          class="primary-button"
          data-admin-modal
        >
          新增教师
        </a>
      </div>
    <% } %>
  </div>
</section>
