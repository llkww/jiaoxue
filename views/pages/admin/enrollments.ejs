<section class="panel">
  <div class="section-head">
    <div>
      <h3 class="section-title">选课数据</h3>
    </div>
  </div>

  <form class="filter-shell mb-4" method="get">
    <input class="form-control" name="keyword" placeholder="搜索学生、课程或开课编号" value="<%= filters.keyword %>" />
    <select class="form-select" name="term_id">
      <option value="">全部学期</option>
      <% terms.forEach(function(item) { %>
        <option value="<%= item.id %>" <%= String(filters.term_id) === String(item.id) ? 'selected' : '' %>><%= item.name %></option>
      <% }) %>
    </select>
    <select class="form-select" name="course_type">
      <option value="">全部课程性质</option>
      <option value="必修" <%= filters.course_type === '必修' ? 'selected' : '' %>>必修</option>
      <option value="选修" <%= filters.course_type === '选修' ? 'selected' : '' %>>选修</option>
    </select>
    <button class="primary-button" type="submit">筛选记录</button>
  </form>

  <% if (enrollments.length) { %>
    <div class="table-scroll table-scroll-module">
      <table class="data-table">
        <thead>
          <tr>
            <th>学生姓名</th>
            <th>学号</th>
            <th>课程名称</th>
            <th>开课编号</th>
            <th>课程性质</th>
            <th>学期</th>
            <th>总评</th>
            <th>选课时间</th>
          </tr>
        </thead>
        <tbody>
          <% enrollments.forEach(function(item) { const failed = item.total_score !== null && Number(item.total_score) < 60; %>
            <tr class="<%= failed ? 'table-row-danger' : '' %>">
              <td><strong><%= item.student_name %></strong></td>
              <td><%= item.student_no %></td>
              <td><%= item.course_name %></td>
              <td><%= item.section_code %></td>
              <td><span class="status-pill <%= badgeClass(item.course_type) %>"><%= item.course_type %></span></td>
              <td><%= item.term_name %></td>
              <td><%= item.total_score === null || item.total_score === undefined ? '--' : formatScore(item.total_score) %></td>
              <td><%= dayjs(item.selected_at).format('YYYY-MM-DD HH:mm') %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="mt-4">
      <%- include('../../partials/pagination', { pagination: pagination }) %>
    </div>
  <% } else { %>
    <%- include('../../partials/empty-state', { title: '暂无符合条件的选课记录', icon: 'solar:list-check-linear' }) %>
  <% } %>
</section>
