<section class="page-grid">
  <div class="panel workspace-panel">
    <div class="section-head">
      <div>
        <h3 class="section-title">学生档案</h3>
      </div>
      <div class="section-actions">
        <a href="/admin/students/new?return_to=<%= encodeURIComponent(returnTo) %>" class="primary-button" data-admin-modal>新增学生</a>
      </div>
    </div>

    <form class="filter-shell mb-4" method="get">
      <input class="form-control" name="keyword" placeholder="搜索学号、姓名或账号" value="<%= filters.keyword %>" />
      <select class="form-select" name="class_id">
        <option value="">全部班级</option>
        <% classes.forEach(function(item) { %>
          <option value="<%= item.id %>" <%= String(filters.class_id) === String(item.id) ? 'selected' : '' %>><%= item.class_name %></option>
        <% }) %>
      </select>
      <button class="primary-button" type="submit">筛选学生</button>
    </form>

    <% if (students.length) { %>
      <div class="table-scroll table-scroll-module">
        <table class="data-table">
          <thead>
            <tr>
              <th>姓名</th>
              <th>性别</th>
              <th>学号</th>
              <th>账号</th>
              <th>班级</th>
              <th>专业</th>
              <th>联系方式</th>
              <th>邮箱</th>
              <th>状态</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% students.forEach(function(item) { %>
              <tr>
                <td><strong><%= item.full_name %></strong></td>
                <td><%= item.gender || '--' %></td>
                <td><%= item.student_no %></td>
                <td><%= item.username %></td>
                <td><%= item.class_name %></td>
                <td><%= item.major_name %></td>
                <td><%= item.phone || '--' %></td>
                <td><%= item.email || '--' %></td>
                <td><span class="status-pill <%= badgeClass(item.user_status) %>"><%= item.user_status %></span></td>
                <td class="table-actions table-actions-wide">
                  <a href="/admin/students/<%= item.id %>/academics?return_to=<%= encodeURIComponent(returnTo) %>" class="ghost-button">学业详情</a>
                  <a href="/admin/students/<%= item.id %>/edit?return_to=<%= encodeURIComponent(returnTo) %>" class="ghost-button" data-admin-modal>编辑</a>
                  <form action="/admin/students/<%= item.id %>" method="post" data-confirm="确认删除该学生账号和档案？">
                    <input type="hidden" name="_method" value="DELETE" />
                    <input type="hidden" name="return_to" value="<%= returnTo %>" />
                    <button type="submit" class="ghost-button">删除</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="mt-4">
        <%- include('../../partials/pagination', { pagination: pagination }) %>
      </div>
    <% } else { %>
      <%- include('../../partials/empty-state', { title: '没有找到符合条件的学生', icon: 'solar:users-group-rounded-linear' }) %>
      <div class="mt-3">
        <a href="/admin/students/new?return_to=<%= encodeURIComponent(returnTo) %>" class="primary-button" data-admin-modal>新增学生</a>
      </div>
    <% } %>
  </div>
</section>
