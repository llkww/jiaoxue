<section class="panel">
  <div class="section-head">
    <div>
      <h3 class="section-title">教师课表</h3>
    </div>
  </div>

  <div class="schedule-scroll">
    <table class="schedule-table">
      <thead>
        <tr>
          <th>节次</th>
          <th>周一</th>
          <th>周二</th>
          <th>周三</th>
          <th>周四</th>
          <th>周五</th>
          <th>周六</th>
          <th>周日</th>
        </tr>
      </thead>
      <tbody>
        <% scheduleRows.forEach(function(row) { %>
          <tr>
            <th>
              <div><%= row.period.label %></div>
              <div class="muted-copy"><%= row.period.time %></div>
            </th>
            <% row.days.forEach(function(day) { %>
              <% if (day && day.skip) { %>
              <% } else if (day) { %>
                <td rowspan="<%= day.span %>">
                  <div class="schedule-card">
                    <strong><%= day.course_name %></strong>
                    <div class="muted-copy"><%= day.section_code %> · <%= day.course_type %></div>
                    <div class="muted-copy mt-2"><%= day.building_name %> <%= day.room_number %></div>
                    <div class="muted-copy"><%= day.label %></div>
                  </div>
                </td>
              <% } else { %>
                <td></td>
              <% } %>
            <% }) %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
